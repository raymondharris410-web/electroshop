{
  "version": 2,
  "builds": [
    {
      "src": "electro_shop/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "electro_shop/wsgi.py"
    }
  ],
  "env": {
    "PYTHONPATH": "/var/task"
  }
}
